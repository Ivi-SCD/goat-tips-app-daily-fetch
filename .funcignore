# Ignore local development artifacts from the Azure Functions deployment package

# Python caches
__pycache__
*.py[cod]
*.pyo

# Local settings (secrets — never deploy)
local.settings.json

# Virtual environments (deps installed separately via pip --target)
.venv
venv
env

# Tests and notebooks
*_test.py
test_*.py
*.ipynb

# Docs and reports
docs/
reports/

# Git
.git
.gitignore

# IDE
.vscode/
.idea/
